/** @typedef {{ queue: string[], player: import('@discordjs/voice').AudioPlayer, connection: import('@discordjs/voice').VoiceConnection | null, playing: boolean, ytdlp: import('child_process').ChildProcess | null }} GuildMusicState */

/** @type {Map<string, GuildMusicState>} */
const guildState = new Map();

/** Стек URL предыдущих треков (для ⏮️), последний = только что уступивший дорогу. */
/** @type {Map<string, string[]>} */
const pastTrackUrlsByGuild = new Map();

const PAST_TRACKS_CAP = 50;

/** Порядок проигранных watch URL за сессию (для ⏮ после доигрывания — не зависит от сокращений past stack). */
/** @type {Map<string, string[]>} */
const sessionPlayedWatchUrlsByGuild = new Map();
const SESSION_PLAYED_CAP = 80;

/**
 * Названия всех треков сыгранных за сессию.
 * Используется как контекст для Groq при предсказании следующего трека автоплея.
 * Пишется всегда (не только при активном автоплее) — чтобы Groq видел полный контекст
 * включая треки добавленные вручную до включения ∞.
 */
/** @type {Map<string, string[]>} */
const autoplaySessionTitlesByGuild = new Map();
const AUTOPLAY_TITLES_CAP = 20;

/**
 * После ⏮ один раз не добавлять urlLeft в past stack при старте «назад» —
 * иначе снова появляется «предыдущий» к текущему и кнопка не гаснет на первом треке.
 * @type {Set<string>}
 */
const suppressHistoryPushByGuild = new Set();

/**
 * После ⏮ с конца очереди: URL трека «вперёд» (тот что только что доиграл), без автоплея —
 * подставляется в очередь только по ⏭ (см. skip).
 * @type {Map<string, string>}
 */
const idleBackForwardTailByGuild = new Map();

/**
 * Индекс в sessionPlayedWatchUrls куда смотрит «текущий» при навигации после idle.
 * Null = навигация не начата (смотрим на последний).
 * @type {Map<string, number>}
 */
const idleNavCursorByGuild = new Map();

/** Повтор текущего трека: true = не сдвигать queue после воспроизведения. */
/** @type {Set<string>} */
const repeatByGuild = new Set();

/** Автоплей: когда очередь кончается, бот сам добавляет похожую подборку. */
/** @type {Set<string>} */
const autoplayByGuild = new Set();

/**
 * Зерно запроса для автоплея — сохраняется из последней подборки или названия трека.
 * @type {Map<string, string>}
 */
const autoplaySeedQueryByGuild = new Map();

/**
 * Оригинальный элемент очереди (queryOrUrl), который сейчас играет.
 * Нужен для того, чтобы при включении repeat в середине трека (когда элемент уже
 * был сдвинут из очереди) вернуть его обратно.
 * @type {Map<string, string>}
 */
const currentQueueItemByGuild = new Map();

/** Переключить повтор для гильдии; возвращает новое состояние. */
export function toggleRepeat(guildId) {
  if (guildId == null) return false;
  const id = String(guildId);
  if (repeatByGuild.has(id)) {
    repeatByGuild.delete(id);
    return false;
  }
  repeatByGuild.add(id);
  /** Repeat и autoplay взаимоисключающие — выключаем autoplay. */
  autoplayByGuild.delete(id);
  /**
   * Если трек уже играет, но был сдвинут из очереди до включения repeat
   * (пользователь включил repeat в середине трека) — вернуть его в начало очереди.
   */
  const s = guildState.get(id);
  const currentItem = currentQueueItemByGuild.get(id);
  if (s?.playing && currentItem && s.queue[0] !== currentItem) {
    s.queue.unshift(currentItem);
  }
  return true;
}

/** Текущее состояние повтора. */
export function isRepeatEnabled(guildId) {
  if (guildId == null) return false;
  return repeatByGuild.has(String(guildId));
}

/** Переключить автоплей; возвращает новое состояние. */
export function toggleAutoplay(guildId) {
  if (guildId == null) return false;
  const id = String(guildId);
  if (autoplayByGuild.has(id)) {
    autoplayByGuild.delete(id);
    return false;
  }
  autoplayByGuild.add(id);
  /** Repeat и autoplay взаимоисключающие — выключаем repeat. */
  repeatByGuild.delete(id);
  return true;
}

/**
 * Сохранить зерно запроса для автоплея (вызывается при подборке).
 * Всегда перезаписывает — подборка является приоритетным источником темы.
 */
export function setAutoplaySeed(guildId, query) {
  if (guildId == null || !query) return;
  autoplaySeedQueryByGuild.set(String(guildId), String(query).trim());
}

/**
 * Установить seed только если он ещё не задан в этой сессии.
 * Используется для одиночных треков — не перезаписывает тему подборки.
 */
export function setAutoplaySeedIfEmpty(guildId, query) {
  if (guildId == null || !query) return;
  const id = String(guildId);
  if (!autoplaySeedQueryByGuild.has(id)) {
    autoplaySeedQueryByGuild.set(id, String(query).trim());
  }
}

/**
 * Модификаторы запроса для автоплея — добавляют лёгкое разнообразие при каждом цикле.
 * Пустые строки намеренно — чаще всего запрос остаётся без изменений.
 */
const AUTOPLAY_MODIFIERS = ['', '', '', '', 'best', 'new', 'similar', 'top', 'classic'];

/** Возвращает слегка варьированный запрос для следующей подборки автоплея. */
function variantAutoplayQuery(base) {
  const mod = AUTOPLAY_MODIFIERS[Math.floor(Math.random() * AUTOPLAY_MODIFIERS.length)];
  return mod ? `${base} ${mod}` : base;
}

/**
 * Ищет трек для автоплея и кладёт URL в очередь. Не вызывает queuePlayNext — это делает runPlayNext.
 * @returns {'queued' | 'skip' | 'fail'}
 */
async function spawnAutoplayPlaylist(guildId, seedQuery) {
  const id = String(guildId);

  /** Groq генерирует умный запрос на основе темы + истории треков. Fallback — стандартный вариант. */
  const playedTitles = autoplaySessionTitlesByGuild.get(id) ?? [];
  let variant;
  if (isGroqConfigured()) {
    try {
      variant = await groqNextTrackQuery(seedQuery, playedTitles);
      console.log(`[autoplay] groq query="${variant}"`);
    } catch (e) {
      variant = variantAutoplayQuery(seedQuery);
      console.log(`[autoplay] groq fallback (${e instanceof Error ? e.message : e}) q="${variant}"`);
    }
  } else {
    variant = variantAutoplayQuery(seedQuery);
  }
  console.log(`[autoplay] spawning guild=${id} q="${variant}"`);
  try {
    const items = await pickDistinctTrackVideos(variant, 1, { skipGroq: true });
    if (!items.length) throw new Error('empty result');

    const s = guildState.get(id);
    if (!s?.connection || s.connection.state.status === VoiceConnectionStatus.Destroyed) return 'skip';
    if (!autoplayByGuild.has(id)) return 'skip';
    if (s.playing || s.queue.length > 0) return 'skip';

    for (const it of items) {
      s.queue.push(it.url);
    }
    console.log(`[autoplay] queued ${items.length} tracks guild=${id}`);
    if (onAutoplaySpawned) {
      try {
        onAutoplaySpawned(id, items, variant);
      } catch {}
    }
    return 'queued';
  } catch (e) {
    console.warn('[autoplay] failed', id, e instanceof Error ? e.message : e);
    return 'fail';
  }
}

/** @type {((guildId: string, items: {title: string, url: string}[], query: string) => void) | null} */
let onAutoplaySpawned = null;

/** Вызывается когда автоплей успешно добавил новую подборку в очередь. */
export function setOnAutoplaySpawned(fn) {
  onAutoplaySpawned = fn;
}

/** @type {((guildId: string) => void) | null} */
let onMusicForceStop = null;

/** Только при «Остановить», авто-выходе из голоса — не при естественном конце очереди. */
export function setOnMusicForceStop(fn) {
  onMusicForceStop = fn;
}

/** @type {((guildId: string, label: string) => void) | null} */
let onPlayingTrackDisplay = null;

/** Смена трека (skip / следующий из очереди) — обновить текст панели в чате. */
export function setOnPlayingTrackDisplay(fn) {
  onPlayingTrackDisplay = fn;
}

/** @type {((guildId: string) => void) | null} */
let onPlaybackIdle = null;

/** Очередь закончилась (или скип последнего), голос ещё подключён — панель в режим ожидания (сообщения в чате не удаляются). */
export function setOnPlaybackIdle(fn) {
  onPlaybackIdle = fn;
}

/** @type {import('discord.js').Client | null} */
let voiceClient = null;

/** URL текущего ролика YouTube — для кнопки «Ещё раз». */
/** @type {Map<string, string>} */
const currentPlayingUrlByGuild = new Map();
/** Человекочитаемое название текущего/последнего трека (для панели и «Ещё раз»). */
/** @type {Map<string, string>} */
const currentPlayingLabelByGuild = new Map();

/** Ссылка на то, что сейчас играет (или последний сыгранный URL), для дубля в очередь. */
export function getRepeatableTrackUrl(guildId) {
  if (guildId == null) return null;
  return currentPlayingUrlByGuild.get(String(guildId)) ?? null;
}

/** Название того же трека, что и у getRepeatableTrackUrl (если есть). */
export function getRepeatableTrackLabel(guildId) {
  if (guildId == null) return null;
  return currentPlayingLabelByGuild.get(String(guildId)) ?? null;
}

function getVoiceEmptyDelayMs() {
  const mins = Number.parseFloat(process.env.VOICE_EMPTY_LEAVE_MINUTES ?? '1');
  const minutes = Number.isFinite(mins) && mins > 0 ? mins : 1;
  return Math.max(1, minutes) * 60_000;
}

/** @type {Map<string, NodeJS.Timeout>} */
const voiceEmptyTimers = new Map();

function clearVoiceEmptyTimer(guildId) {
  const t = voiceEmptyTimers.get(guildId);
  if (t) clearTimeout(t);
  voiceEmptyTimers.delete(guildId);
}

/**
 * Если в голосе остались только боты — через N минут выходим из канала.
 * @param {import('discord.js').Client} client
 */
export function attachVoiceAutoLeave(client) {
  voiceClient = client;
  const ms = getVoiceEmptyDelayMs();

  client.on('voiceStateUpdate', (oldState, newState) => {
    const guild = newState.guild ?? oldState.guild;
    if (!guild) return;
    void checkVoiceChannelEmpty(guild, ms);
  });
}

/**
 * @param {import('discord.js').Guild} guild
 * @param {number} delayMs
 */
async function checkVoiceChannelEmpty(guild, delayMs) {
  const conn = getVoiceConnection(guild.id);
  if (!conn) {
    clearVoiceEmptyTimer(guild.id);
    return;
  }
  const channelId = conn.joinConfig.channelId;
  if (!channelId) {
    clearVoiceEmptyTimer(guild.id);
    return;
  }

  try {
    await guild.voiceStates.fetch();
  } catch {
    /* ignore */
  }

  const ch = await guild.channels.fetch(channelId).catch(() => null);
  if (!ch?.isVoiceBased()) {
    clearVoiceEmptyTimer(guild.id);
    return;
  }

  const humans = ch.members.filter((m) => !m.user.bot).size;
  if (humans > 0) {
    clearVoiceEmptyTimer(guild.id);
    return;
  }

  if (voiceEmptyTimers.has(guild.id)) return;
  const t = setTimeout(() => {
    voiceEmptyTimers.delete(guild.id);
    void (async () => {
      const g = await voiceClient?.guilds.fetch(guild.id).catch(() => null);
      if (!g) return;
      const conn = getVoiceConnection(guild.id);
      if (!conn) return;
      const cid = conn.joinConfig.channelId;
      if (!cid) return;
      try {
        await g.voiceStates.fetch();
      } catch {
        /* ignore */
      }
      const vch = await g.channels.fetch(cid).catch(() => null);
      if (!vch?.isVoiceBased()) return;
      if (vch.members.filter((m) => !m.user.bot).size > 0) return;
      stopAndLeave(guild.id);
      console.log(
        `[music] авто-выход из голоса (нет людей ${Math.round(delayMs / 60000)} мин), guild ${guild.id}`,
      );
    })();
  }, delayMs);
  voiceEmptyTimers.set(guild.id, t);
}

function killYtdlp(s) {
  if (!s?.ytdlp) return;
  try {
    s.ytdlp.kill('SIGKILL');
  } catch {
    /* ignore */
  }
  s.ytdlp = null;
}

/** Уточняет запрос, чтобы чаще находить именно трек, а не обзор/разбор. */
function augmentYoutubeSearchQuery(q) {
  const s = q.trim();
  if (!s) return s;
  const wantsTheme =
    /опенинг|опеннинг|\bopening\b|\bop\s|opening\s|\[op\]|эндинг|\bending\b|\bed\s|саундтрек|soundtrack|\bost\b|тема\s+из/i.test(
      s,
    );
  if (!wantsTheme) return s;
  if (/full\s+(song|version)|theme\s+song|lyrics|караоке|karaoke|tv\s*size/i.test(s)) return s;
  return `${s} full opening theme song lyrics`;
}

