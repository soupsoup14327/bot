# PAWPAW bot — environment template
# Copy to .env and fill in secrets.
# Regenerate from registry: node scripts/generate-env-example.mjs
# Validate drift:         node scripts/generate-env-example.mjs --check

# === [core] Discord core ===
DISCORD_TOKEN=your_bot_token_here  # Discord bot token.
DISCORD_CLIENT_ID=your_application_id_here  # Application ID for slash command registration.
# DISCORD_GUILD_ID=  # Guild id or comma-separated guild ids for fast command sync.
# DISCORD_KEEP_GLOBAL_COMMANDS=0  # Keep global slash commands when guild-scoped registration is enabled.
# TRACK_PLAYS_RETENTION_PER_USER=500  # Keep only the newest N playback-history rows per user. 0 disables pruning.

# === [groq] Groq (ИИ для /chat и автоплея) ===
GROQ_API_KEY=  # Groq API key for chat and autoplay generation.
# GROQ_MODEL=llama-3.1-8b-instant  # Model for autoplay generation tasks.
# GROQ_CHAT_MODEL=llama-3.3-70b-versatile  # Model for /chat.
# GROQ_TIMEOUT_MS=8000  # Request timeout for Groq API calls.
# GROQ_AUTOPLAY_TEMPERATURE=0.55  # Sampling temperature for autoplay prompting.
# GROQ_AUTOPLAY_NEGATIVE_CONTEXT=1  # Use negative context in autoplay prompting.
# GROQ_AUTOPLAY_NEGATIVE_LIMIT=4  # Max number of negative context tokens for autoplay.

# === [autoplay] Autoplay (движок подбора треков) ===
# AUTOPLAY_CANDIDATES_PER_QUERY=8  # How many YouTube candidates are retrieved per query.
# AUTOPLAY_PLAYABILITY_CACHE_SHADOW=0  # Collect playability cache without hard blocking candidates.
# AUTOPLAY_PLAYABILITY_HARD_SKIP_ENABLED=0  # Skip candidates known as unplayable.
# AUTOPLAY_PLAYABILITY_CACHE_TTL_MS=604800000  # TTL for unplayable URL cache entries.
# AUTOPLAY_FAST_LANE_ENABLED=0  # Enable reduced-Groq retrieval path when scenario is stable.
# AUTOPLAY_FAST_LANE_QUERY_BUDGET=6  # Query budget for fast-lane retrieval.
# AUTOPLAY_STALE_GUARD_ENABLED=1  # Drop stale in-flight autoplay generations by generation id.
# AUTOPLAY_ESCAPE_ENABLED=0  # Enable temporary escape branches after basin quick-skip patterns.
# AUTOPLAY_ESCAPE_T_MS=  # Optional override for escape trial dwell threshold in milliseconds. If unset, derived from MUSIC_QUICK_SKIP_MS with a 30s cap.
# AUTOPLAY_ESCAPE_COOLDOWN_SPAWNS=2  # How many autoplay spawns stay in normal-continue mode after a failed D fallback.
# AUTOPLAY_DISTINCT_ARTIST_SHORTLIST_ENABLED=0  # Enable pre-ranker shortlist deduplication so only one known-artist candidate survives the first pass.
# AUTOPLAY_DISTINCT_ARTIST_MIN_CANDIDATES=4  # If the one-per-artist shortlist is smaller than this, relax the shortlist to allow limited repeats.
# AUTOPLAY_DISTINCT_ARTIST_MAX_PER_ARTIST_FALLBACK=2  # Per-artist cap used by the relaxed distinct shortlist fallback.
# AUTOPLAY_ARTIST_QUARANTINE_ENABLED=0  # Enable hard per-artist quarantine for quick-skipped tracks before candidate ranking.
# AUTOPLAY_ARTIST_QUARANTINE_SPAWNS=1  # How many autoplay spawn attempts quarantine a quick-skipped lead artist.
# AUTOPLAY_RECOVERY_GROQ_ONLY=0  # Limit Groq use to recovery mode after bad spawn streak.
# AUTOPLAY_RECOVERY_STREAK_MIN=2  # Bad spawn streak threshold to enter recovery mode.
# AUTOPLAY_ALT_VARIANTS_RELAXED=0  # Relax alt-version filtering for better recall.
# AUTOPLAY_ALT_STREAK_MIN=2  # Consecutive alt-version threshold before penalty.
# AUTOPLAY_ALT_STREAK_PENALTY=38  # Penalty applied for sustained alt-version streaks.
# AUTOPLAY_VARIETY_CONTROLLER_ENABLED=1  # Enable anti-repeat variety controller (default ON, set 0 to disable).
# AUTOPLAY_VARIETY_BUDGET_EXPERIMENTAL=0  # Enable experimental 70/30 query budget split.
# AUTOPLAY_VARIETY_ARTIST_SOFT_PENALTY=12  # Soft score penalty for repeating artists.
# AUTOPLAY_VARIETY_ARTIST_STRONG_PENALTY=32  # Strong score penalty for repeating artists.
# AUTOPLAY_VARIETY_FAMILY_STREAK_BASE=8  # Base penalty for repetitive query family streaks.
# AUTOPLAY_VARIETY_FAMILY_STREAK_MULT=1.35  # Multiplier for repetitive query family streak penalty.
# AUTOPLAY_RANKER_SEARCH_WEIGHT=1  # Weight of search score in candidate ranker.
# AUTOPLAY_RANKER_SIGNAL_WEIGHT=0.35  # Weight of local signal boost in ranker.
# AUTOPLAY_RANKER_EXACT_PAIR_WEIGHT=1  # Weight for exact pair match bonus.
# AUTOPLAY_RANKER_ANCHOR_MISS_WEIGHT=1  # Weight for identity-anchor miss penalty.
# AUTOPLAY_RANKER_FALLBACK_PENALTY=8  # Penalty for fallback candidates in ranker.
# AUTOPLAY_ARTIST_COOLDOWN_ENABLED=1  # Enable artist cooldown in candidate ranker (default ON, set 0 to disable).
# AUTOPLAY_ARTIST_COOLDOWN_WINDOW=8  # Artist cooldown lookback window size.
# AUTOPLAY_POLICY_ENABLED=1  # Enable autoplay query policy and anti-loop controls.
# AUTOPLAY_TOKEN_LOOP_MIN=3  # Loop threshold for repeated query token mitigation.
# AUTOPLAY_STRONG_AVOID_MIN=2  # Threshold for strong avoid list application.
# AUTOPLAY_QUERY_QUARANTINE_WINDOW=8  # Window length for query quarantine logic.
# AUTOPLAY_QUERY_FAMILY_MAX_STREAK=3  # Max same-family query streak before diversification.
# AUTOPLAY_PREFETCH_MIN_POOL=2  # Skip prefetch when pool already has at least this many candidates.
# AUTOPLAY_PREFETCH_FAST_DELAY_MS=1000  # Milliseconds before fast prefetch phase runs.
# AUTOPLAY_PREFETCH_FULL_DELAY_MS=15000  # Milliseconds before full prefetch phase runs.

# === [signals] Signals & recommendation bridge ===
# MUSIC_SIGNALS_ENABLED=1  # Enable in-memory track events signal bus.
# MUSIC_SIGNALS_BUFFER=100  # Per-guild ring buffer size for signals.
# MUSIC_SIGNALS_MAX_AGE_H=24  # Retention period for persisted signals in hours.
# MUSIC_QUICK_SKIP_MS=5000  # Threshold for quick skip classification and boost logic.
# MUSIC_BRIDGE_ENABLED=1  # Enable recommendation bridge (local boost + optional server).
# MUSIC_SIGNALS_ENDPOINT=  # Recommendation bridge sync endpoint URL.
# MUSIC_SIGNALS_API_KEY=  # Bearer token for recommendation bridge sync endpoint.
# MUSIC_BRIDGE_SERVER_TIMEOUT_MS=4000  # Timeout for bridge server requests.

# === [playback] Playback, voice, yt-dlp ===
# VOICE_EMPTY_LEAVE_MINUTES=1  # Minutes before leaving voice when channel is empty.
# AUDIO_NORMALIZE=1  # Enable ffmpeg normalize filter for track playback.
# AUDIO_FFMPEG_AF=  # Custom ffmpeg -af filter string (overrides default normalize filter).
# YT_DLP_AUTO_UPDATE=1  # Enable periodic youtube-dl-exec updater.
# YT_DLP_UPDATE_INTERVAL_HOURS=24  # Update interval for yt-dlp in hours.
# YT_DLP_UPDATE_DELAY_MS=8000  # Initial delay before first yt-dlp update check.
# MAX_CONCURRENT_YTDLP=3  # Max concurrent yt-dlp processes for streaming (audio-pipeline).
# MAX_CONCURRENT_YTDLP_SEARCH=5  # Max concurrent yt-dlp search processes (youtube-search).

# === [metrics] Metrics & debug ===
# METRICS_TXT_ENABLED=1  # Enable metrics writes to data/metrics/*.txt.
# AUTOPLAY_DEBUG=0  # Verbose autoplay trace logs.
# AUTOPLAY_BASELINE_LOG=0  # Emit baseline autoplay telemetry events.
# DEBUG_PLAYBACK=0  # Verbose playback scheduler debug logs.
# ORCHESTRATOR_DEBUG=0  # Log orchestrator command calls to console.

# ---------------------------------------------------------------------------
# Data layer (см. docs/adr/001-data-layer.md)
#
# Один DATABASE_URL управляет всем data-слоем. Schema в URL выбирает backend.
# Если переменная не задана:
#   - под `node --test` / NODE_ENV=test → sqlite::memory: (in-memory)
#   - в остальных случаях              → sqlite:./data/local.db (file)
#
# Примеры (раскомментировать нужное):
#
# In-memory SQLite — автотесты, CI matrix job `test-sqlite`:
# DATABASE_URL=sqlite::memory:
#
# File SQLite — локальная разработка (default для запуска без env):
# DATABASE_URL=sqlite:./data/local.db
#
# PostgreSQL — managed / production-like окружение:
# DATABASE_URL=postgres://user:password@host:5432/dbname
#
# Test-safety: в тестовом режиме допустимы ТОЛЬКО sqlite::memory: и
# sqlite:./data/test/*.db. Любой другой URL валит процесс немедленно
# (см. docs/adr/001-data-layer.md §3 Test-safety invariant).
# ---------------------------------------------------------------------------
# DATABASE_URL=sqlite:./data/local.db
