{
  "name": "pawpaw-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "verify": "node scripts/verify-modules.mjs && node scripts/generate-env-example.mjs --check && node scripts/verify-env.mjs && node --test",
    "verify:env": "node scripts/generate-env-example.mjs --check && node scripts/verify-env.mjs",
    "env:example": "node scripts/generate-env-example.mjs",
    "env:example:check": "node scripts/generate-env-example.mjs --check",
    "env:setup": "node scripts/env-easy.mjs setup",
    "env:doctor": "node scripts/env-easy.mjs doctor",
    "env:preset:stable": "node scripts/env-easy.mjs preset stable",
    "env:preset:conservative": "node scripts/env-easy.mjs preset conservative",
    "kill-bots": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-bot-instances.ps1",
    "register-commands": "node src/register-commands.js",
    "postinstall": "node -e \"require('fs').copyFileSync('node_modules/libsodium/dist/modules-esm/libsodium.mjs','node_modules/libsodium-wrappers/dist/modules-esm/libsodium.mjs')\""
  },
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.2.0",
    "libsodium": "^0.7.16",
    "libsodium-wrappers": "^0.7.16",
    "play-dl": "^1.9.7",
    "youtube-dl-exec": "^3.1.5"
  }
}
